---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import * as prismic from '@prismicio/client';
import { withBase } from '../config/site';

interface Props {
  slice?: any;
  eyebrow?: string;
  heading?: string;
  body?: string; // html
  ctaLabel?: string;
  ctaHref?: string; // base-less internal path, e.g. '/rooms/'
  image?: ImageMetadata;
  imageAlt?: string;
  flip?: boolean;
}

const {
  slice,
  eyebrow,
  heading,
  body,
  ctaLabel,
  ctaHref,
  image,
  imageAlt = '',
  flip = false,
} = Astro.props;

const p = slice?.primary;

/** Plain text from a Prismic Text or StructuredText field. */
const text = (f: any): string => (typeof f === 'string' ? f : f ? (prismic.asText(f) ?? '') : '');

/** Internal paths (Prismic values and props are base-less) get the deploy base. */
const resolveHref = (href?: string | null): string | undefined =>
  href ? (href.startsWith('/') ? withBase(href) : href) : undefined;

const finalEyebrow = (p ? text(p.eyebrow) : '') || eyebrow;

const headingHtml =
  p?.heading && text(p.heading).trim()
    ? prismic.asHTML(p.heading)
    : heading
      ? `<h2>${heading}</h2>`
      : '';

const bodyHtml = p?.body && text(p.body).trim() ? prismic.asHTML(p.body) : (body ?? '');

const finalCtaLabel = (p ? text(p.cta_label) : '') || ctaLabel;
const sliceLink = p?.cta_link
  ? typeof p.cta_link === 'string'
    ? p.cta_link
    : prismic.asLink(p.cta_link)
  : undefined;
const finalHref = resolveHref(sliceLink || ctaHref);

const flipped = p?.layout ? p.layout === 'flipped' : flip;
const prismicImage = p?.image?.url ? p.image : undefined;
---

<section class="section container">
  <div class:list={['feature', 'reveal', { 'feature--flip': flipped }]}>
    {
      prismicImage ? (
        <img
          src={prismicImage.url}
          alt={prismicImage.alt ?? imageAlt}
          width={prismicImage.dimensions?.width}
          height={prismicImage.dimensions?.height}
          loading="lazy"
        />
      ) : image ? (
        <Image
          src={image}
          alt={imageAlt}
          widths={[600, 1200]}
          sizes="(min-width: 50rem) 50vw, 100vw"
        />
      ) : null
    }
    <div class="feature__text">
      {finalEyebrow && <span class="eyebrow">{finalEyebrow}</span>}
      {headingHtml && <div class="feature__heading" set:html={headingHtml} />}
      {bodyHtml && <div class="feature__body" set:html={bodyHtml} />}
      {
        finalCtaLabel && finalHref && (
          <a class="btn feature__cta" href={finalHref}>
            {finalCtaLabel}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .feature__heading :global(h2) {
    margin-bottom: var(--space-s);
  }

  .feature__heading :global(em) {
    font-style: italic;
  }

  .feature__body :global(p) {
    margin: 0 0 var(--space-s);
  }

  .feature__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .feature__cta {
    margin-top: var(--space-s);
  }
</style>
